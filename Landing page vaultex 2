<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Vaultex AI // Researcher</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #12111a;
      --bg2: #1a1828;
      --purple: #a78bfa;
      --blue: #60a5fa;
      --pink: #e879f9;
      --text: #c4b5fd;
      --muted: #6b6a85;
      --grad: linear-gradient(90deg, #a78bfa, #60a5fa);
      --btn-grad: linear-gradient(135deg, #a78bfa 0%, #60a5fa 100%);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: 'Space Mono', monospace;
      overflow-x: hidden;
    }

    /* ── BACKGROUND PATTERN ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        repeating-linear-gradient(
          45deg,
          transparent,
          transparent 60px,
          rgba(167,139,250,0.03) 60px,
          rgba(167,139,250,0.03) 61px
        ),
        repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 60px,
          rgba(96,165,250,0.03) 60px,
          rgba(96,165,250,0.03) 61px
        );
      pointer-events: none;
      z-index: 0;
    }

    section, nav, footer { position: relative; z-index: 1; }

    /* ── NAV ── */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 24px;
      border-bottom: 1px solid rgba(167,139,250,0.1);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(18,17,26,0.85);
    }

    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1rem;
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 0.1em;
    }

    .nav-links {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--purple); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 24px 60px;
    }

    .accent-line {
      width: 180px;
      height: 3px;
      background: var(--grad);
      margin-bottom: 40px;
      border-radius: 2px;
    }

    .hero h1 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2.8rem, 12vw, 5.5rem);
      line-height: 1.0;
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 28px;
      letter-spacing: -0.01em;
    }

    .hero p {
      font-size: 0.95rem;
      color: var(--text);
      margin-bottom: 40px;
      line-height: 1.7;
      max-width: 340px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--btn-grad);
      color: #12111a;
      font-family: 'Space Mono', monospace;
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 18px 28px;
      border-radius: 6px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.2s;
      width: 100%;
      justify-content: center;
    }

    .btn:hover { opacity: 0.88; transform: translateY(-2px); }

    .btn-outline {
      background: transparent;
      border: 1px solid var(--purple);
      color: var(--purple);
      margin-top: 14px;
    }

    .btn-outline:hover { background: rgba(167,139,250,0.1); }

    /* ── SECTION HEADERS ── */
    .section-label {
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .section-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2rem, 9vw, 3.5rem);
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.05;
      margin-bottom: 32px;
    }

    /* ── CASE STUDIES ── */
    #case-studies {
      padding: 80px 24px;
      border-top: 1px solid rgba(167,139,250,0.1);
    }

    .case-card {
      background: rgba(26,24,40,0.8);
      border: 1px solid rgba(167,139,250,0.15);
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 40px;
    }

    .case-card-img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      background: linear-gradient(135deg, #1e1b2e 0%, #2d2a45 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      color: var(--muted);
      letter-spacing: 0.1em;
    }

    .case-card-body { padding: 24px; }

    .case-number {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: var(--purple);
      margin-bottom: 10px;
    }

    .case-title {
      font-family: 'Syne', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: #e2d9ff;
      margin-bottom: 16px;
    }

    .data-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 20px;
    }

    .data-item {
      background: rgba(167,139,250,0.07);
      border-radius: 6px;
      padding: 12px;
    }

    .data-label {
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .data-value {
      font-size: 0.85rem;
      color: var(--purple);
      font-weight: 700;
    }

    .case-desc {
      font-size: 0.78rem;
      line-height: 1.75;
      color: var(--text);
      margin-bottom: 20px;
    }

    .btn-row {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    /* ── ANALYSIS ── */
    #analysis {
      padding: 80px 24px;
      border-top: 1px solid rgba(167,139,250,0.1);
    }

    .stat-block {
      border-left: 2px solid var(--purple);
      padding: 16px 20px;
      margin-bottom: 20px;
      background: rgba(167,139,250,0.05);
      border-radius: 0 8px 8px 0;
    }

    .stat-block h3 {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      color: var(--purple);
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .stat-block p {
      font-size: 0.8rem;
      line-height: 1.7;
      color: var(--text);
    }

    /* ── ABOUT ── */
    #about {
      padding: 80px 24px;
      border-top: 1px solid rgba(167,139,250,0.1);
    }

    #about p {
      font-size: 0.82rem;
      line-height: 1.85;
      color: var(--text);
      margin-bottom: 16px;
    }

    /* ── PRODUCTS ── */
    #products {
      padding: 80px 24px;
      border-top: 1px solid rgba(167,139,250,0.1);
    }

    .product-card {
      background: rgba(26,24,40,0.8);
      border: 1px solid rgba(96,165,250,0.2);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 20px;
    }

    .product-tag {
      display: inline-block;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: var(--blue);
      border: 1px solid rgba(96,165,250,0.3);
      border-radius: 4px;
      padding: 3px 10px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .product-title {
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: #e2d9ff;
      margin-bottom: 10px;
    }

    .product-desc {
      font-size: 0.78rem;
      line-height: 1.7;
      color: var(--text);
      margin-bottom: 18px;
    }

    /* ── FOOTER ── */
    footer {
      padding: 60px 24px 40px;
      border-top: 1px solid rgba(167,139,250,0.1);
      text-align: center;
    }

    .footer-divider {
      width: 120px;
      height: 2px;
      background: var(--grad);
      margin: 0 auto 32px;
      border-radius: 2px;
    }

    .footer-disclaimer {
      font-size: 0.72rem;
      line-height: 1.8;
      color: var(--muted);
      margin-bottom: 20px;
    }

    .footer-contact {
      font-size: 0.72rem;
      color: var(--purple);
      margin-bottom: 28px;
    }

    .social-icons {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-bottom: 32px;
    }

    .social-icons a {
      color: var(--pink);
      font-size: 1.3rem;
      text-decoration: none;
      transition: color 0.2s, transform 0.2s;
    }

    .social-icons a:hover { color: var(--purple); transform: translateY(-3px); }

    .footer-copy {
      font-size: 0.65rem;
      color: var(--muted);
      letter-spacing: 0.1em;
    }

    /* ── FADE IN ANIMATION ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero h1  { animation: fadeUp 0.7s ease both; }
    .hero p   { animation: fadeUp 0.7s 0.15s ease both; }
    .hero .btn { animation: fadeUp 0.7s 0.3s ease both; }
  </style>
</head>
